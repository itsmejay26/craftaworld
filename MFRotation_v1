--[[
    MFRot_Tester.lua
    Execute while the farm is running.
    Each button instantly skips that phase so you can test the
    full world-switch and rotation loop without waiting.
]]

local Players = game:GetService("Players")
local UIS     = game:GetService("UserInputService")
local player  = Players.LocalPlayer
local gui     = player:WaitForChild("PlayerGui")

local old = gui:FindFirstChild("MFRot_TesterGui")
if old then old:Destroy() end

local sg = Instance.new("ScreenGui", gui)
sg.Name = "MFRot_TesterGui"; sg.ResetOnSpawn = false
sg.IgnoreGuiInset = true; sg.DisplayOrder = 9999

local win = Instance.new("Frame", sg)
win.Size             = UDim2.new(0, 230, 0, 210)
win.Position         = UDim2.new(1, -240, 0, 10)
win.BackgroundColor3 = Color3.fromRGB(14, 18, 14)
win.BorderSizePixel  = 0; win.ClipsDescendants = true
Instance.new("UICorner", win).CornerRadius = UDim.new(0, 10)
local ws = Instance.new("UIStroke", win)
ws.Color = Color3.fromRGB(80, 160, 80); ws.Thickness = 1.5

local bar = Instance.new("Frame", win)
bar.Size = UDim2.new(1, 0, 0, 30)
bar.BackgroundColor3 = Color3.fromRGB(24, 36, 24); bar.BorderSizePixel = 0
Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 10)
local barFill = Instance.new("Frame", bar)
barFill.Size = UDim2.new(1, 0, 0, 10); barFill.Position = UDim2.new(0, 0, 1, -10)
barFill.BackgroundColor3 = Color3.fromRGB(24, 36, 24); barFill.BorderSizePixel = 0

local titleLbl = Instance.new("TextLabel", bar)
titleLbl.Size = UDim2.new(1, -36, 1, 0); titleLbl.Position = UDim2.new(0, 8, 0, 0)
titleLbl.BackgroundTransparency = 1; titleLbl.Text = "MFRot Tester"
titleLbl.TextColor3 = Color3.fromRGB(120, 220, 130)
titleLbl.TextSize = 11; titleLbl.Font = Enum.Font.GothamBold
titleLbl.TextXAlignment = Enum.TextXAlignment.Left

local closeBtn = Instance.new("TextButton", bar)
closeBtn.Size = UDim2.new(0, 22, 0, 22); closeBtn.Position = UDim2.new(1, -26, 0.5, -11)
closeBtn.BackgroundColor3 = Color3.fromRGB(160, 50, 50); closeBtn.BorderSizePixel = 0
closeBtn.Text = "x"; closeBtn.TextColor3 = Color3.new(1,1,1)
closeBtn.TextSize = 14; closeBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 5)
closeBtn.MouseButton1Click:Connect(function() sg:Destroy() end)

local dragging, dragStart, startPos = false, nil, nil
bar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = i.Position; startPos = win.Position
    end
end)
UIS.InputChanged:Connect(function(i)
    if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
        local d = i.Position - dragStart
        win.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X,
                                  startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end
end)
UIS.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

local statusLbl = Instance.new("TextLabel", win)
statusLbl.Size = UDim2.new(1, -16, 0, 18); statusLbl.Position = UDim2.new(0, 8, 0, 36)
statusLbl.BackgroundTransparency = 1; statusLbl.Text = "Waiting for farm..."
statusLbl.TextColor3 = Color3.fromRGB(160, 200, 160)
statusLbl.TextSize = 9; statusLbl.Font = Enum.Font.Gotham
statusLbl.TextXAlignment = Enum.TextXAlignment.Left
statusLbl.TextTruncate = Enum.TextTruncate.AtEnd

local function mkBtn(label, yPos, col)
    local b = Instance.new("TextButton", win)
    b.Size = UDim2.new(1, -16, 0, 28); b.Position = UDim2.new(0, 8, 0, yPos)
    b.BackgroundColor3 = col; b.BorderSizePixel = 0
    b.Text = label; b.TextColor3 = Color3.new(1, 1, 1)
    b.TextSize = 11; b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    return b
end

local C_HARVEST = Color3.fromRGB(160, 120, 30)
local C_BREAK   = Color3.fromRGB(130, 60, 160)
local C_PLANT   = Color3.fromRGB(40, 120, 60)
local C_ALL     = Color3.fromRGB(180, 60, 60)

local hBtn = mkBtn("Skip Harvest  -> Break",  62, C_HARVEST)
local bBtn = mkBtn("Skip Break    -> Plant",   98, C_BREAK)
local pBtn = mkBtn("Skip Plant    -> Storage", 134, C_PLANT)
local aBtn = mkBtn("Skip ALL phases",          170, C_ALL)

local function setStatus(msg, col)
    statusLbl.Text = msg
    statusLbl.TextColor3 = col or Color3.fromRGB(255, 220, 100)
end

hBtn.MouseButton1Click:Connect(function()
    _G._MFRot_SkipHarvest = true
    setStatus("Skipping harvest — takes effect at next row...", Color3.fromRGB(255,220,100))
    hBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 80)
    task.wait(0.5); hBtn.BackgroundColor3 = C_HARVEST
end)

bBtn.MouseButton1Click:Connect(function()
    _G._MFRot_SkipBreak = true
    setStatus("Skipping break — takes effect within 1 fire...", Color3.fromRGB(200,140,255))
    bBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 80)
    task.wait(0.5); bBtn.BackgroundColor3 = C_BREAK
end)

pBtn.MouseButton1Click:Connect(function()
    _G._MFRot_SkipPlant = true
    setStatus("Skipping plant — takes effect at next row...", Color3.fromRGB(120,255,150))
    pBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 80)
    task.wait(0.5); pBtn.BackgroundColor3 = C_PLANT
end)

aBtn.MouseButton1Click:Connect(function()
    _G._MFRot_SkipHarvest = true
    _G._MFRot_SkipBreak   = true
    _G._MFRot_SkipPlant   = true
    setStatus("All phases skipped!", Color3.fromRGB(255,120,120))
    aBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 80)
    task.wait(0.5); aBtn.BackgroundColor3 = C_ALL
end)

task.spawn(function()
    while sg and sg.Parent do
        task.wait(0.3)
        local sl = _G._MFRot_StatusLabel
        if sl and sl.Parent then
            statusLbl.Text       = sl.Text
            statusLbl.TextColor3 = sl.TextColor3
        elseif _G.MFRotInst and not _G.MFRotInst.dead then
            statusLbl.Text       = "Farm running"
            statusLbl.TextColor3 = Color3.fromRGB(150, 200, 150)
        else
            statusLbl.Text       = "Farm not running"
            statusLbl.TextColor3 = Color3.fromRGB(180, 130, 130)
        end
    end
end)

print("[MFRot Tester] Ready.")
