-- MFRotation_Start.lua
-- Shows the farm GUI. AutoWorldSwitch.lua (Autoexecute) must have run first.

local gui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
local mfGui = gui:FindFirstChild("MFRotGui")

if mfGui then
    -- GUI exists — un-minimize and show it
    local main = mfGui:FindFirstChild("Main")
    if main then
        main.Visible = true
        for _, c in pairs(main:GetDescendants()) do
            if c:IsA("TextButton") and c.Text == "+" then
                c.Text = "−"
                main.Size = UDim2.new(0, 360, 0, 396)
                local sf = main:FindFirstChildOfClass("ScrollingFrame")
                if sf then sf.Visible = true end
                break
            end
        end
    end
    print("[MFRot] GUI shown.")
else
    -- Still in lobby — autoexec returned early without building GUI.
    -- The GUI will be built automatically once you enter a world.
    print("[MFRot] Still in lobby — GUI will appear once you enter a world.")
end
