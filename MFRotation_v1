--[[
    MFRotation_Start.lua  ·  STARTUP SCRIPT
    Execute this once to show the Multi Farm Rotation GUI.
    AutoWorldSwitch.lua runs automatically via Autoexecute.
]]

local player = game:GetService("Players").LocalPlayer
local gui    = player:WaitForChild("PlayerGui")

-- If the GUI is already running (autoexec loaded it), just show it
local mfGui = gui:FindFirstChild("MFRotGui")

if mfGui then
    local main = mfGui:FindFirstChild("Main")
    if main then
        main.Visible = true
        -- If minimized, expand it
        for _, child in pairs(main:GetDescendants()) do
            if child:IsA("TextButton") and child.Text == "+" then
                child.Text = "−"
                main.Size  = UDim2.new(0, 360, 0, 396)
                local sf   = main:FindFirstChildOfClass("ScrollingFrame")
                if sf then sf.Visible = true end
                break
            end
        end
    end
    print("[MFRot Start] GUI shown.")

else
    -- Autoexec hasn't fired yet — load from workspace root
    -- (AutoWorldSwitch.lua saves itself here on first run)
    local FILE = "AutoWorldSwitch.lua"
    if isfile and isfile(FILE) then
        local ok, src = pcall(readfile, FILE)
        if ok and src and src ~= "" then
            local ok2, fn = pcall(loadstring, src)
            if ok2 and fn then
                pcall(fn)
                print("[MFRot Start] Loaded AutoWorldSwitch.lua")
            else
                warn("[MFRot Start] Failed to compile AutoWorldSwitch.lua")
            end
        end
    else
        warn("[MFRot Start] AutoWorldSwitch.lua not found in workspace.")
        warn("[MFRot Start] Make sure AutoWorldSwitch.lua is in your Autoexecute folder.")
        warn("[MFRot Start] It will save itself to workspace on first load.")
    end
end
