local function whFmtTime(secs)
    secs = math.floor(secs)
    local h = math.floor(secs / 3600)
    local m = math.floor((secs % 3600) / 60)
    local s = secs % 60
    if h > 0 then return h.."h "..m.."m "..s.."s" end
    if m > 0 then return m.."m "..s.."s" end
    return s.."s"
end

local function whGetPingMs()
    local ok, val = pcall(function()
        return game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    if ok and val and val > 0 then return math.floor(val) end
    local t0 = tick(); RunSvc.Heartbeat:Wait()
    local ms = math.floor((tick() - t0) * 1000)
    return ms > 0 and ms or 0
end

-- whRequest: find the executor's HTTP function and fire the webhook.
-- Tries every known executor function name so it works across executors.
local function whRequest(payload)
    -- Collect all possible request functions (executor-specific)
    local reqFn =  (typeof(syn)          == "table"    and syn.request)
                or (typeof(http_request) == "function" and http_request)
                or (typeof(request)      == "function" and request)
                or (typeof(fluxus)       == "table"    and fluxus.request)
                or (typeof(http)         == "table"    and http and http.request)
    if not reqFn then
        warn("[MFRot Webhook] No HTTP request function found in this executor!")
        return
    end
    local body = HttpSvc:JSONEncode(payload)
    local ok, err = pcall(reqFn, {
        Url     = WEBHOOK_URL,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = body,
    })
    if not ok then
        warn("[MFRot Webhook] Request failed: " .. tostring(err))
    end
end

-- whSend: build the embed and fire it. Called on every phase change + periodically.
local function whSend(phase)
    task.spawn(function()
        local ok, err = pcall(function()
            local OSTime = os.time()
            local Time   = os.date("!*t", OSTime)
            local pingMs  = whGetPingMs()
            local isOnline = pingMs > 0

            -- Safe inventory reads
            local seeds  = CFG.plantItem and GetTotalByCode(CFG.plantItem) or 0
            local blocks = CFG.breakItem and GetTotalByCode(CFG.breakItem) or 0

            -- Gems from GemsUI
            local gems = "N/A"
            pcall(function()
                gems = player.PlayerGui.GemsUI.Frame.TextLabel.Text
            end)

            -- Build a drop summary: "ItemCode x123, ItemCode x45"
            local dropParts = {}
            for _, entry in ipairs(CFG.dropList) do
                local qty = GetTotalByCode(entry.code)
                table.insert(dropParts, "["..entry.code.."] x"..qty
                    ..(entry.unstackable and " (1×1)" or " (×"..entry.dropAmt..")"))
            end
            local dropsStr = #dropParts > 0 and table.concat(dropParts, "\n") or "None set"

            local pingStr    = isOnline and (pingMs.."ms") or "N/A"
            local botStatus  = isOnline and "🟢 Online"    or "🔴 Offline"
            local embedColor = isOnline and 3066993         or 15158332
            local contentMsg = isOnline and ""              or "@everyone"

            local uptimeStr = whStartTime and whFmtTime(tick() - whStartTime) or "N/A"
            local cycle1Str = "N/A"
            if whCycle1End then
                cycle1Str = whFmtTime(whCycle1End - (whCycle1Start or whStartTime or whCycle1End))
            elseif whCycle1Start then
                cycle1Str = whFmtTime(tick() - whCycle1Start) .. " (ongoing)"
            end

            local worldStr = whCurrentWorld ~= "" and whCurrentWorld or "—"

            whRequest({
                content = contentMsg,
                embeds  = {{
                    title  = "📋 Multi Farm Rotation Logs",
                    color  = embedColor,
                    fields = {
                        { name = "⚙️ Phase",        value = phase,           inline = false },
                        { name = "🤖 Bot",          value = WH_BOT_USERNAME, inline = true  },
                        { name = "📡 Status",       value = botStatus,       inline = true  },
                        { name = "🏓 Ping",         value = pingStr,         inline = true  },
                        { name = "🌍 World",        value = worldStr,        inline = true  },
                        { name = "⏱ Uptime",       value = uptimeStr,       inline = true  },
                        { name = "🔁 Cycle 1 Time", value = cycle1Str,       inline = true  },
                        { name = "🌱 Seeds",        value = tostring(seeds), inline = true  },
                        { name = "🧱 Blocks",       value = tostring(blocks),inline = true  },
                        { name = "💎 Gems",         value = gems,            inline = true  },
                        { name = "📦 Drop Items",   value = dropsStr,        inline = false },
                    },
                    timestamp = string.format("%d-%02d-%02dT%02d:%02d:%02dZ",
                        Time.year, Time.month, Time.day, Time.hour, Time.min, Time.sec),
                    footer = { text = "MFRot v1.0  •  Job: "..tostring(game.JobId):sub(1,8) },
                }},
                allowed_mentions = { parse = { "everyone" } },
            })
            print("[MFRot Webhook] Sent: " .. phase)
        end)
        if not ok then
            warn("[MFRot Webhook] whSend error: " .. tostring(err))
        end
    end)
end

