--[[
    AutoWorldSwitch.lua  ·  AUTO-EXECUTE SCRIPT
    ═══════════════════════════════════════════════════════════════
    Place this file in your executor's Autoexecute folder.
    It runs automatically on EVERY server load — no manual steps.

    Full automated flow:
      1. Reads craftaworld/pending_world.txt for a target world
      2. If in lobby + pending world found:
           → Show "Joining [world]..." overlay GUI
           → Fire tp:FireServer(worldName)
           → Wait until fully inside the world (Tiles loaded)
           → Load MFRotation_v1.lua  ← this script auto-resumes
             the farm because SaveProgress(true) was called before
             the world switch
      3. If in a world + pending world found:
           → Keep target saved and exit to lobby
             (next load handles the join)
      4. If no pending world:
           → Just load MFRotation_v1.lua normally (manual mode,
             user presses START themselves)
    ═══════════════════════════════════════════════════════════════
]]

local DATA_FILE  = "craftaworld/pending_world.txt"
local MAIN_FILE  = "MFRotation_v1.lua"

local RS         = game:GetService("ReplicatedStorage")
local Players    = game:GetService("Players")
local player     = Players.LocalPlayer
local gui        = player:WaitForChild("PlayerGui")

-- ── Helpers ──────────────────────────────────────────────────────
local function isInLobby()
    return RS:FindFirstChild("tp") ~= nil
end

local function worldIsLoaded()
    if isInLobby() then return false end
    local tf = workspace:FindFirstChild("Tiles")
    return tf ~= nil and #tf:GetChildren() > 0
end

local function removeLobbyGui()
    local g = gui:FindFirstChild("MFRot_LobbyGui")
    if g then g:Destroy() end
end

-- Minimal overlay shown while in lobby / joining
local function makeLobbyGui(msg)
    removeLobbyGui()
    local sg = Instance.new("ScreenGui", gui)
    sg.Name = "MFRot_LobbyGui"; sg.ResetOnSpawn = false
    sg.IgnoreGuiInset = true; sg.DisplayOrder = 9999

    local bg = Instance.new("Frame", sg)
    bg.Size = UDim2.new(0, 300, 0, 64)
    bg.Position = UDim2.new(0.5, -150, 0.5, -32)
    bg.BackgroundColor3 = Color3.fromRGB(16, 22, 18)
    bg.BorderSizePixel = 0
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 10)
    local s = Instance.new("UIStroke", bg)
    s.Color = Color3.fromRGB(55, 140, 70); s.Thickness = 1.5

    local title = Instance.new("TextLabel", bg)
    title.Size = UDim2.new(1, -12, 0, 20); title.Position = UDim2.new(0, 10, 0, 6)
    title.BackgroundTransparency = 1
    title.Text = "Multi Farm Rotation v1.0"
    title.TextColor3 = Color3.fromRGB(100, 165, 115)
    title.TextSize = 10; title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left

    local lbl = Instance.new("TextLabel", bg)
    lbl.Size = UDim2.new(1, -12, 0, 28); lbl.Position = UDim2.new(0, 10, 0, 28)
    lbl.BackgroundTransparency = 1
    lbl.Text = msg
    lbl.TextColor3 = Color3.fromRGB(180, 255, 195)
    lbl.TextSize = 12; lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    return lbl  -- return label so caller can update text
end

-- Load and execute MFRotation_v1.lua
local function loadMainScript()
    if not (isfile and isfile(MAIN_FILE)) then
        warn("[AutoWorldSwitch] " .. MAIN_FILE .. " not found.")
        warn("[AutoWorldSwitch] Execute MFRotation_v1.lua once manually to register it.")
        return false
    end
    local ok, src = pcall(readfile, MAIN_FILE)
    if not ok or not src or src == "" then
        warn("[AutoWorldSwitch] Could not read " .. MAIN_FILE); return false
    end
    local ok2, fn = pcall(loadstring, src)
    if not ok2 or not fn then
        warn("[AutoWorldSwitch] Failed to compile " .. MAIN_FILE .. ": " .. tostring(fn))
        return false
    end
    local ok3, err = pcall(fn)
    if not ok3 then
        warn("[AutoWorldSwitch] Error running " .. MAIN_FILE .. ": " .. tostring(err))
        return false
    end
    return true
end

-- ── Main logic ───────────────────────────────────────────────────
task.spawn(function()
    task.wait(3)  -- wait for game to initialize

    -- Read pending world
    local hasPending = false
    local target = ""
    local ok, content = pcall(readfile, DATA_FILE)
    if ok and content and content ~= "" then
        target = content:match("^%s*(.-)%s*$") or ""
        if target ~= "" then hasPending = true end
    end

    if hasPending then
        if isInLobby() then
            -- ── IN LOBBY: join target world ───────────────────────
            local lbl = makeLobbyGui("Joining  " .. target .. "...")

            -- Animate dots while joining
            local joining = true
            task.spawn(function()
                local dots = 0
                while joining do
                    dots = (dots % 3) + 1
                    if lbl and lbl.Parent then
                        lbl.Text = "Joining  " .. target .. string.rep(".", dots)
                    end
                    task.wait(0.5)
                end
            end)

            -- Clear file BEFORE firing so it doesn't re-trigger on
            -- the next load if something goes wrong
            pcall(function() writefile(DATA_FILE, "") end)
            task.wait(0.8)

            -- Fire join
            local tp = RS:FindFirstChild("tp")
            if tp then
                pcall(function() tp:FireServer(target) end)
            end

            -- Wait until we leave the lobby
            local t1 = tick()
            while isInLobby() and tick() - t1 < 30 do
                task.wait(0.3)
            end

            -- Wait until Tiles folder populates (world is fully loaded)
            if lbl and lbl.Parent then
                lbl.Text = "Loading  " .. target .. "..."
            end
            local t2 = tick()
            while not worldIsLoaded() and tick() - t2 < 60 do
                task.wait(0.4)
            end

            joining = false
            task.wait(1.5)  -- extra settle for tile watcher

            if lbl and lbl.Parent then
                lbl.Text = "Joined " .. target .. " — starting farm..."
            end
            task.wait(0.5)
            removeLobbyGui()

            -- Load and run the main farm script
            -- It will auto-resume because SaveProgress(true) was
            -- called before the world switch
            loadMainScript()

        else
            -- ── IN A WORLD: save target and exit to lobby ─────────
            print("[AutoWorldSwitch] In world — saving target and exiting to lobby")
            makeLobbyGui("Switching to  " .. target .. "...")
            pcall(function() writefile(DATA_FILE, target) end)
            task.wait(0.5)
            local exitR = Remotes and Remotes:FindFirstChild("RequestPlayerExitWorld")
            if not exitR then
                local r = RS:FindFirstChild("Remotes")
                if r then exitR = r:FindFirstChild("RequestPlayerExitWorld") end
            end
            if exitR then pcall(function() exitR:InvokeServer() end) end
            -- GUI disappears naturally on server switch
        end

    else
        -- ── NO PENDING WORLD: load main script normally ───────────
        -- The script will show its full GUI; user sets up and presses START.
        -- (If autoResume is saved from a previous session it will also
        --  auto-start, but that's handled inside MFRotation_v1.lua)
        print("[AutoWorldSwitch] No pending world. Loading main script...")
        task.wait(0.5)
        loadMainScript()
    end
end)

print("[AutoWorldSwitch] Loaded. Waiting 3s then checking pending world...")
