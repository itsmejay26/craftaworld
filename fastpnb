-- ============ MAIN AUTO PNB LOOP ============
playBtn.MouseButton1Click:Connect(function()
    if isRunning then return end
    if not itemCode then SetSt("No item selected!", Color3.fromRGB(220,85,85)); return end

    local px, py = GetTilePos()
    if not px or not py then SetSt("Can't detect tile position!", Color3.fromRGB(220,85,85)); return end

    -- Lock target tile position at start time
    local offX, offY = GetTileOffset(selectedTileIdx)
    local targetPos = Vector2.new(px+offX, py+offY)
    liveTileTarget = targetPos   -- also drives the live tile state display

    isRunning = true
    SetSt("[ RUNNING ]  "..tostring(itemCode), Color3.fromRGB(75,210,105))

    task.spawn(function()
        -- Safety caps: if tile detection lags/fails, we still cycle
        -- instead of hanging in one phase forever.
        -- 120 fires @ 0.01s ≈ 1.2s max place burst before forcing break
        -- 600 fires @ 0.01s ≈ 6.0s max break burst before forcing place
        local MAX_PLACE = 120
        local MAX_BREAK = 600

        while isRunning and not inst.dead do

            -- ═══════════════════════════════════════════════
            --  PLACE PHASE
            --  Fire placeR at 0.01 until tile detected as present
            --  OR until MAX_PLACE fires (safety fallback).
            -- ═══════════════════════════════════════════════
            SetPhase("PLACING", Color3.fromRGB(85,210,115))
            SetSt("[ PLACING ]  "..tostring(itemCode), Color3.fromRGB(85,210,115))

            local placeFires = 0
            while isRunning and not inst.dead do
                local slotN = FindSlotForCode(itemCode)
                if not slotN then
                    isRunning = false
                    liveTileTarget = nil
                    SetPhase("IDLE", Color3.fromRGB(140,125,180))
                    SetSt("[ STOPPED — Item empty! ]", Color3.fromRGB(220,85,85))
                    break
                end
                placeR:FireServer(targetPos, slotN)
                task.wait(FIRE_SPEED)
                placeFires += 1
                if IsTileAt(targetPos) then break end       -- tile appeared → go break
                if placeFires >= MAX_PLACE then break end   -- safety: force break phase
            end

            if not isRunning or inst.dead then break end

            -- ═══════════════════════════════════════════════
            --  BREAK PHASE
            --  Fire fistR at 0.01 until tile detected as gone
            --  OR until MAX_BREAK fires (safety fallback).
            -- ═══════════════════════════════════════════════
            SetPhase("BREAKING", Color3.fromRGB(220,150,50))
            SetSt("[ BREAKING ]  "..tostring(itemCode), Color3.fromRGB(220,150,50))

            local breakFires = 0
            while isRunning and not inst.dead do
                fistR:FireServer(targetPos)
                task.wait(FIRE_SPEED)
                breakFires += 1
                if not IsTileAt(targetPos) then break end   -- tile gone → go place
                if breakFires >= MAX_BREAK then break end   -- safety: force place phase
            end

            -- Zero delay — immediately loop back to place phase
        end

        -- Cleanup on stop/exit
        liveTileTarget = nil
        SetPhase("IDLE", Color3.fromRGB(140,125,180))
        if stLbl and stLbl.Parent then SetSt("[ IDLE ]", Color3.fromRGB(140,125,180)) end
    end)
end)

stopBtn.MouseButton1Click:Connect(function()
    isRunning = false
    liveTileTarget = nil
    SetPhase("IDLE", Color3.fromRGB(140,125,180))
    SetSt("[ STOPPED ]", Color3.fromRGB(185,150,150))
end)

print("[Auto Fast PnB v1.0] Ready.")
