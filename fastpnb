-- ============ LIVE WORLD TILE CHECKER ============
-- Searches for a foreground tile at the given tile grid coordinates.
-- Uses a TIGHT Z range (3 studs) so background / floor parts behind the playfield
-- are NOT counted.  Also filters by size so large decorative panels are ignored.
local function IsTileAt(tileVec2)
    local wx = tileVec2.X * TILE_SIZE
    local wy = tileVec2.Y * TILE_SIZE
    local cf = CFrame.new(wx, wy, 0)
    -- Tight box: small XY so we stay within one tile cell, shallow Z so we
    -- don't accidentally catch background geometry.
    local searchBox = Vector3.new(TILE_SIZE * 0.75, TILE_SIZE * 0.75, 3)

    local params = OverlapParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local excludeList = {}
    local char = player.Character
    if char then table.insert(excludeList, char) end
    params.FilterDescendantsInstances = excludeList

    local ok, parts = pcall(function()
        return workspace:GetPartBoundsInBox(cf, searchBox, params)
    end)
    if not ok or not parts then return false end

    for _, part in pairs(parts) do
        if part:IsA("BasePart") and part ~= workspace.Terrain then
            local sz = part.Size
            -- Accept only parts that are roughly tile-sized in X and Y
            -- (rejects giant background panels, thin decoration strips, etc.)
            if sz.X <= TILE_SIZE * 1.5 and sz.Y <= TILE_SIZE * 1.5
            and sz.X >= 0.8 and sz.Y >= 0.8 then
                return true
            end
        end
    end
    return false
end

